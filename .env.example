# =============================================================================
# AM Collective — Environment Variables
# Copy to .env.local and fill in values. See docs/PRD.md Section 12 for details.
# =============================================================================

# Clerk Authentication
# Get from: https://dashboard.clerk.com > AM Collective app > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon PostgreSQL
# Get from: https://console.neon.tech > amcollective-prod project > Connection Details
DATABASE_URL=

# Stripe
# Get from: https://dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend Email
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# PostHog Analytics
# Get from: https://us.posthog.com > Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking
# Get from: https://sentry.io > AM Collective project > Settings > Client Keys
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ArcJet Security
# Get from: https://app.arcjet.com > Settings > API Keys
ARCJET_KEY=

# Upstash Redis (Rate Limiting)
# Get from: https://console.upstash.com > Redis database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest Background Jobs
# Get from: https://app.inngest.com > Settings > Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Anthropic Claude AI
# Get from: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Vercel API (for project connector)
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# Firecrawl (Research Agent)
# Get from: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Tavily (Research Agent)
# Get from: https://app.tavily.com/home
TAVILY_API_KEY=

# Bloo.io Messaging
# Get from: Bloo.io dashboard
BLOOIO_API_KEY=

# Mercury Banking
# Get from: https://app.mercury.com > Settings > API
MERCURY_API_KEY=
MERCURY_SANDBOX=false

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

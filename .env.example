# =============================================================================
# AM Collective — Environment Variables
# Copy to .env.local and fill in values. See docs/PRD.md Section 12 for details.
# =============================================================================

# Clerk Authentication
# Get from: https://dashboard.clerk.com > AM Collective app > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon PostgreSQL
# Get from: https://console.neon.tech > amcollective-prod project > Connection Details
DATABASE_URL=

# Stripe
# Get from: https://dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend Email
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# PostHog Analytics
# Get from: https://us.posthog.com > Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking
# Get from: https://sentry.io > AM Collective project > Settings > Client Keys
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ArcJet Security
# Get from: https://app.arcjet.com > Settings > API Keys
ARCJET_KEY=

# Upstash Redis (Rate Limiting)
# Get from: https://console.upstash.com > Redis database > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Inngest Background Jobs
# Get from: https://app.inngest.com > Settings > Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Anthropic Claude AI
# Get from: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# OpenAI (embeddings + semantic search)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vault Encryption (required for credential storage)
# Generate with: openssl rand -hex 32
CREDENTIALS_SECRET=

# Vercel API (for project connector)
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=

# Slack Incoming Webhook
# Get from: api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=

# Firecrawl (Research Agent)
# Get from: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Tavily (Research Agent)
# Get from: https://app.tavily.com/home
TAVILY_API_KEY=

# Bloo.io Messaging
# Get from: Bloo.io dashboard
BLOOIO_API_KEY=

# Mercury Banking
# Get from: https://app.mercury.com > Settings > API
MERCURY_API_KEY=
MERCURY_SANDBOX=false

# Linear Issue Tracking
# Get from: https://linear.app > Settings > API > Personal API Keys
LINEAR_API_KEY=

# Admin Access
# Comma-separated Clerk user IDs that always get admin access
SUPER_ADMIN_USER_IDS=user_2vqM8MZ1z7MxvJRLjJolHJAGnXp
# Comma-separated emails that always get "owner" role
SUPER_ADMIN_EMAILS=adamwolfe102@gmail.com,maggie@amcollectivecapital.com

# Composio (Tool Orchestration)
COMPOSIO_API_KEY=
COMPOSIO_ENTITY_ID=

# Dash0 (Observability)
DASH0_API_KEY=
DASH0_DATASET=

# EmailBison
EMAILBISON_API_KEY=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=amcollective

# PostHog (Project ID for connector)
POSTHOG_PROJECT_ID=

# Stripe (Multi-project account IDs, comma-separated)
STRIPE_ACCOUNT_IDS=

# Wholesail Connector
WHOLESAIL_CONNECTOR_SECRET=

# Clerk Webhook
CLERK_WEBHOOK_SECRET=

# Bloo.io Messaging (additional)
BLOOIO_FROM_NUMBER=
BLOOIO_WEBHOOK_SECRET=

# Bot / OpenClaw Integration
BOT_INTERNAL_SECRET=
OPENCLAW_SHARED_SECRET=
OPENCLAW_WEBHOOK_URL=

# Team Identity (Clerk IDs, phones, Slack user IDs for bot routing)
ADAM_CLERK_ID=
ADAM_PHONE=
ADAM_SLACK_ID=
MAGGIE_CLERK_ID=
MAGGIE_PHONE=
MAGGIE_SLACK_ID=

# Email Configuration
AM_COLLECTIVE_FROM_EMAIL=team@amcollectivecapital.com
RESEND_FROM_EMAIL=team@amcollectivecapital.com
DIGEST_EMAIL=
OPS_NAME=
OPS_NOTIFICATION_EMAIL=

# Cross-Project Connectors (read-only DB access to spoke projects)
CURSIVE_ANON_KEY=
CURSIVE_DATABASE_URL=
TASKSPACE_DATABASE_URL=
TRACKR_DATABASE_URL=
WHOLESAIL_DATABASE_URL=

# GitHub Knowledge Base
GITHUB_KNOWLEDGE_OWNER=
GITHUB_KNOWLEDGE_REPO=
GITHUB_PAT=

# Intake Webhook
INTAKE_WEBHOOK_SECRET=

# Linear (additional)
LINEAR_WEBHOOK_SECRET=

# Neon API (for connector metrics)
NEON_API_KEY=

# Sentry (additional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog (additional — personal API key for server-side connector)
POSTHOG_PERSONAL_API_KEY=

# Composio (additional)
COMPOSIO_GMAIL_AUTH_CONFIG=
COMPOSIO_WEBHOOK_SECRET=

# EmailBison (additional)
EMAILBISON_BASE_URL=https://api.emailbison.com

# Slack (additional — bot token + signing for interactive Slack integration)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Site URL (public)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

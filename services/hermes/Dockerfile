# Hermes Agent — Fly.io deployment image
#
# Builds Hermes from the upstream NousResearch repo and runs the Slack
# Socket Mode gateway as the foreground process.
#
# Persistent state (skills, memory, session DB) lives at /root/.hermes,
# which is backed by a Fly volume mounted in fly.toml.

FROM python:3.11-slim

# ── System dependencies ────────────────────────────────────────────────────
# git: clone Hermes
# build-essential: native deps for some Python packages
# ffmpeg: voice transcription (optional but cheap to include)
# ca-certificates + curl: TLS + uv installer
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        build-essential \
        ca-certificates \
        curl \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# ── Install Hermes ─────────────────────────────────────────────────────────
# Pin to main; version drift is intentionally cheap to recover from since
# the agent is stateful and lives in /root/.hermes.
WORKDIR /opt
RUN git clone --depth 1 https://github.com/NousResearch/hermes-agent.git
WORKDIR /opt/hermes-agent

# Use uv for fast, reliable installs.
RUN pip install --no-cache-dir uv \
    && uv pip install --system --no-cache-dir -e ".[all]"

# ── Hermes state directory ─────────────────────────────────────────────────
# This path is volume-mounted on Fly. First-boot config is generated by
# entrypoint.sh and then persists across restarts.
RUN mkdir -p /root/.hermes
VOLUME /root/.hermes

# ── Entrypoint ─────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
COPY health.py /opt/hermes-agent/health.py
COPY seed_crons.py /opt/hermes-agent/seed_crons.py
RUN chmod +x /entrypoint.sh

# Hermes makes outbound websocket + HTTPS only — no inbound port needed.
# Fly's healthcheck is process-based, see fly.toml.
ENTRYPOINT ["/entrypoint.sh"]
